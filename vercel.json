{
  "version": 2,
  "builds": [
    {
      "src": "apps/server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/client/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/client/dist/$1"
    }
  ]
}
