# ======================
# OddsLens 환경 변수 예시
# ======================

# 📋 이 파일을 복사해 .env 파일을 만드세요:
# cp .env.example .env

# ========== 서버 전용 (클라이언트에 절대 노출 금지) ==========

# Google Gemini API 키 (필수)
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 모델명 (기본값: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# 서버 포트 (기본값: 8787)
PORT=8787

# 클라이언트 오리진 (CORS 허용 주소)
CLIENT_ORIGIN=http://localhost:5173

# 데모 모드 (true 시 실제 API 대신 목업 데이터 반환)
# API 키 없이 테스트할 때 사용
MOCK=false

# ========== 선택 사항 ==========

# 스포츠 데이터 API (없어도 동작, Gemini 웹검색으로 대체)
# SPORTS_API_KEY=

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info
